# config.py
"""
App-level config เท่านั้น — dataset config ย้ายไปอยู่ใน datasets/<dataset>.yaml แล้ว

Dataset schema, category mapping, NLP rules → ดึงจาก registry:
    from datasets.registry import load_dataset, build_schema_prompt
    ds = load_dataset("<dataset>")
"""

# ── App Config ───────────────────────────────────────────────
HISTORY_FILE = ""
MAX_HISTORY = 50
GPT_MODEL = "gpt-4o-mini"

# ── Dataset (lazy-loaded) ────────────────────────────────────
_dataset_cache: dict = {}


def get_dataset(name: str):
    """
    โหลด DatasetConfig (cached) — ใช้แทน TABLE_SCHEMA / CATEGORY_MAPPING hardcode

    Example:
        from config import get_dataset
        ds = get_dataset()
        hive_db = ds.database       
        table   = ds.curated_table   
    """
    if name not in _dataset_cache:
        from datasets.registry import load_dataset
        _dataset_cache[name] = load_dataset(name)
    return _dataset_cache[name]


def get_hive_database(name: str) -> str:
    return get_dataset(name).database


def get_table_schema_prompt(name: str) -> str:
    """
    สร้าง TABLE_SCHEMA string สำหรับส่งให้ GPT
    ใช้แทน TABLE_SCHEMA constant เดิม
    """
    from datasets.registry import build_schema_prompt
    return build_schema_prompt(get_dataset(name))